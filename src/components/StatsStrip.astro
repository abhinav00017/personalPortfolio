---
import { stats } from "../data/profile";
---

<section class="stats-strip" aria-label="Career snapshot">
  <div class="section-shell stats-grid">
    {
      stats.map((item) => (
        <div class="stat-item">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </div>
      ))
    }
  </div>
</section>
